# Copie para .env e ajuste conforme o ambiente.
# cp .env.example .env
#
# Usar SQLite em desenvolvimento (sem PostgreSQL):
USE_SQLITE=1
#
# Permite executar o comando management `superuser_list` em ambientes onde DEBUG=False.
# Atenção: habilitar em produção só sob controle estrito.
ALLOW_ADMIN_LIST=1
